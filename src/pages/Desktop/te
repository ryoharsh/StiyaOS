// High-Performance Memoized Window Component
const Window = React.memo<WindowProps>(({ app, onClose, onFocus, onMinimize, onMaximize, frameConstraints, children }) => {
    const [size, setSize] = useState({ width: app.defaultSize.width, height: app.defaultSize.height });
    const [position, setPosition] = useState({ x: app.x, y: app.y });
    const [lastClickTime, setLastClickTime] = useState(0);
    const [previousState, setPreviousState] = useState({ size: { width: app.defaultSize.width, height: app.defaultSize.height }, position: { x: app.x, y: app.y } });
    const dragControls = useDragControls();

    useEffect(() => {
        if (app.state === 'maximized') {
            setPreviousState({ size: { ...size }, position: { ...position } });
            setSize({ width: window.innerWidth, height: window.innerHeight - 70 });
            setPosition({ x: 0, y: 0 });
        } else if (app.state === 'open') {
            setSize(previousState.size);
            setPosition(previousState.position);
        }
    }, [app.state]);

    const getAnimationProps = () => {
        const startX = window.innerWidth / 2 - size.width / 2;
        const common = { initial: { opacity: 0, scale: 0.8, y: window.innerHeight, x: startX }, animate: { opacity: 1, scale: 1, y: position.y, x: position.x }, exit: { opacity: 0, scale: 0.9, y: window.innerHeight } };
        if (['opening', 'closing', 'maximized'].includes(app.state)) return common;
        return { initial: { opacity: 1, scale: 1 }, animate: { opacity: 1, scale: 1, x: position.x, y: position.y, width: size.width, height: size.height }, exit: { opacity: 0, scale: 0.95 } };
    };

    if (app.state === 'minimized') return null;

    return (
        <AnimatePresence>
            <motion.div
                key={app.instanceId}
                drag dragListener={false} dragControls={dragControls} dragElastic={0} dragMomentum={false} dragConstraints={frameConstraints}
                onDrag={(e, info) => { setPosition({ x: info.point.x, y: info.point.y }); }}
                {...getAnimationProps()}
                transition={{ duration: 0.2, ease: 'easeOut' }}
                style={{
                    zIndex: app.zIndex, position: 'absolute',
                    left: app.state === 'maximized' ? 0 : position.x, top: app.state === 'maximized' ? 0 : position.y,
                    width: app.state === 'maximized' ? '100vw' : size.width, height: app.state === 'maximized' ? `calc(100vh - 65px)` : size.height
                }}
                onMouseDown={() => onFocus(app.instanceId)}
                className="bg-white/80 backdrop-blur-2xl rounded-xl shadow-2xl flex flex-col overflow-hidden window-app border border-white/20"
            >
                {!app.windowOptions?.hideTitleBar && (
                    <div
                        onPointerDown={(e) => {
                            const now = Date.now();
                            if (now - lastClickTime < 300) { onMaximize(app.instanceId); return; }
                            setLastClickTime(now);
                            if (app.state !== 'maximized') dragControls.start(e);
                        }}
                        className="title-bar flex items-center justify-between h-10 bg-white/40 px-3 border-b border-white/30 flex-shrink-0 cursor-move"
                    >
                        <div className="flex items-center gap-2 pointer-events-none">
                            <img src={app.icon} alt={app.name} className="w-5 h-5" />
                            <p className="font-semibold text-xs text-gray-800">{app.name}</p>
                        </div>
                        <div className="flex items-center gap-2 pointer-events-auto">
                            <div onClick={(e) => { e.stopPropagation(); onMinimize(app.instanceId); }} className="w-3.5 h-3.5 bg-yellow-400 rounded-full hover:bg-yellow-500 cursor-pointer" />
                            <div onClick={(e) => { e.stopPropagation(); onMaximize(app.instanceId); }} className="w-3.5 h-3.5 bg-green-500 rounded-full hover:bg-green-600 cursor-pointer" />
                            <div onClick={(e) => { e.stopPropagation(); onClose(app.instanceId); }} className="w-3.5 h-3.5 bg-red-500 rounded-full hover:bg-red-600 cursor-pointer" />
                        </div>
                    </div>
                )}
                <div className="flex-grow overflow-hidden bg-white/50">{children}</div>
                {app.state !== 'maximized' && (
                    <motion.div onPan={(_e, info) => setSize(p => ({ width: Math.max(300, p.width + info.delta.x), height: Math.max(200, p.height + info.delta.y) }))} className="absolute bottom-0 right-0 w-4 h-4 cursor-se-resize z-10" />
                )}
            </motion.div>
        </AnimatePresence>
    );
}, (prev, next) => prev.app.state === next.app.state && prev.app.zIndex === next.app.zIndex && prev.app.instanceId === next.app.instanceId);

