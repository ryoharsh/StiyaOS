// --- Main Desktop Application ---

export default function DesktopPage() {
    const [openWindows, setOpenWindows] = useState<DesktopAppInstance[]>([]);
    const [icons, setIcons] = useState<MyApp[]>([]);
    const [taskbarIcons, setTaskbarIcons] = useState<MyApp[]>([]);
    const [selectedIcons, setSelectedIcons] = useState<Set<string>>(new Set());
    const [selectionBox, setSelectionBox] = useState<SelectionBox | null>(null);
    const [zIndexCounter, setZIndexCounter] = useState<number>(10);
    const [focusedWindow, setFocusedWindow] = useState<string>("desktop");

    // UI Panels
    const [isBotOpen, setIsBotOpen] = useState(false);
    const [isStartMenuOpen, setStartMenuOpen] = useState(false);
    const [batteryStatus, setBatteryStatus] = useState<BatteryStatus>({ level: 100, charging: false });

    const desktopRef = useRef<HTMLDivElement>(null);
    const draggingIconInfo = useRef<any>(null);

    // Initial arrangement
    useEffect(() => {
        let currentX = ICON_PADDING_X;
        let currentY = TOP_MARGIN;
        const screenHeight = window.innerHeight - 60; // Approximate taskbar height

        const initialIcons = Object.values(desktopAppRegistry).map(app => {
            if (currentY + ICON_HEIGHT > screenHeight) { currentY = TOP_MARGIN; currentX += GRID_SIZE_X; }
            const icon = { ...app, x: currentX, y: currentY };
            currentY += GRID_SIZE_Y;
            return icon;
        });

        setIcons(initialIcons);
        setTaskbarIcons(Object.values(taskBarAppsRegistry).map(app => ({ ...app, x: 0, y: 0 })));
    }, []);

    // Voice Recognition ("Hey Stiya")
    useEffect(() => {
        const SpeechRecognition = (window as any).SpeechRecognition || (window as any).webkitSpeechRecognition;
        if (!SpeechRecognition) return;

        const recognition = new SpeechRecognition();
        recognition.continuous = true;
        recognition.interimResults = false;
        
        recognition.onresult = (event: any) => {
            const transcript = event.results[event.results.length - 1][0].transcript.toLowerCase();
            if (transcript.includes("hey stiya") || transcript.includes("hi stiya")) {
                setIsBotOpen(true);
            }
        };

        recognition.onend = () => {
            try { recognition.start(); } catch (e) {} // Restart silently if it stops
        };

        try { recognition.start(); } catch (e) { console.warn("Mic access denied or error starting."); }
        return () => { recognition.onend = null; recognition.stop(); };
    }, []);

    // API Context Implementations
    const getRunningInstances = useCallback((appId: string) => openWindows.filter(w => w.id === appId && w.state !== "closing"), [openWindows]);

    const getAppDefinition = (appId: string): AppDefinition | undefined => allApps[appId as keyof typeof allApps];
    
    const handleFocusWindow = useCallback((instanceId: string) => {
        setZIndexCounter(z => z + 1);
        setFocusedWindow("window");
        setOpenWindows(prev => prev.map(w => w.instanceId === instanceId ? { ...w, zIndex: zIndexCounter + 1, state: w.state === "minimized" ? "open" : w.state } : w).sort((a, b) => a.zIndex - b.zIndex));
    }, [zIndexCounter]);

    const handleCloseWindow = useCallback((instanceId: string) => {
        setOpenWindows(prev => prev.map(w => w.instanceId === instanceId ? { ...w, state: "closing" } : w));
        setTimeout(() => setOpenWindows(prev => prev.filter(w => w.instanceId !== instanceId)), 200);
    }, []);

    const createNewAppInstance = useCallback((appId: string, appDef: AppDefinition) => {
        setZIndexCounter(z => z + 1);
        const x = (window.innerWidth - appDef.defaultSize.width) / 2 + (openWindows.length * WINDOW_CASCADE_OFFSET) % 200;
        const y = (window.innerHeight - appDef.defaultSize.height) / 2 + (openWindows.length * WINDOW_CASCADE_OFFSET) % 200;

        const newWindow: DesktopAppInstance = { ...appDef, instanceId: `${appId}-${Date.now()}`, x, y, zIndex: zIndexCounter + 1, state: "opening" };
        setOpenWindows(prev => [...prev, newWindow]);
        setTimeout(() => setOpenWindows(prev => prev.map(w => w.instanceId === newWindow.instanceId ? { ...w, state: "open" } : w)), 200);
    }, [openWindows.length, zIndexCounter]);

    const handleOpenApp = useCallback((appId: string) => {
        const appDef = getAppDefinition(appId);
        if (!appDef) return;
        const running = getRunningInstances(appId);
        if (running.length === 0) createNewAppInstance(appId, appDef);
        else handleFocusWindow(running[running.length - 1].instanceId); // Focus top-most if already running
    }, [getRunningInstances, createNewAppInstance, handleFocusWindow]);

    const appManagerValue: AppManagerAPI = {
        openApp: handleOpenApp,
        createAppInstance: appId => { const appDef = getAppDefinition(appId); if (appDef) createNewAppInstance(appId, appDef); },
        closeInstance: handleCloseWindow,
        closeAllInstancesOfApp: appId => setOpenWindows(p => p.filter(w => w.id !== appId)),
        getRunningInstances: getRunningInstances as any,
        focusInstance: handleFocusWindow
    };

    // Desktop Interactions
    const handleDesktopMouseDown = (e: React.MouseEvent) => {
        if ((e.target as HTMLElement).closest(".window-app, .taskbar")) return;
        setSelectedIcons(new Set());
        setSelectionBox({ x: e.clientX, y: e.clientY, width: 0, height: 0 });

        const onMove = (me: MouseEvent) => {
            const w = me.clientX - e.clientX;
            const h = me.clientY - e.clientY;
            setSelectionBox({ x: w > 0 ? e.clientX : me.clientX, y: h > 0 ? e.clientY : me.clientY, width: Math.abs(w), height: Math.abs(h) });
        };
        const onUp = () => { document.removeEventListener("mousemove", onMove); document.removeEventListener("mouseup", onUp); setSelectionBox(null); };
        document.addEventListener("mousemove", onMove); document.addEventListener("mouseup", onUp);
    };

    const handleIconMouseDown = useCallback((e: React.MouseEvent, id: string) => {
        e.stopPropagation();
        if (e.detail === 2) { handleOpenApp(id); return; }
        
        const newSel = (e.ctrlKey || e.metaKey) ? new Set(selectedIcons) : new Set([id]);
        if (e.ctrlKey || e.metaKey) newSel.has(id) ? newSel.delete(id) : newSel.add(id);
        setSelectedIcons(newSel);

        const initialPos = icons.reduce((acc: any, icon) => { if (newSel.has(icon.id)) acc[icon.id] = { x: icon.x, y: icon.y }; return acc; }, {});
        draggingIconInfo.current = { startX: e.clientX, startY: e.clientY, initialPos, selection: newSel };

        const onMove = (me: MouseEvent) => {
            const dx = me.clientX - draggingIconInfo.current.startX;
            const dy = me.clientY - draggingIconInfo.current.startY;
            setIcons(prev => prev.map(icon => newSel.has(icon.id) ? { ...icon, x: initialPos[icon.id].x + dx, y: initialPos[icon.id].y + dy } : icon));
        };
        const onUp = () => { document.removeEventListener("mousemove", onMove); document.removeEventListener("mouseup", onUp); };
        document.addEventListener("mousemove", onMove); document.addEventListener("mouseup", onUp);
    }, [handleOpenApp, icons, selectedIcons]);

    // Derived Taskbar active icons logic
    const activeTaskbarApps = Array.from(new Set([...taskbarIcons.map(t => t.id), ...openWindows.map(w => w.id)]));

    return (
        <AppManagerProvider value={appManagerValue}>
            <div className="w-screen h-screen overflow-hidden bg-black font-sans text-sm selection:bg-blue-500/30">
                {/* Background */}
                <img src={WALLPAPER} className="w-full h-full object-cover absolute inset-0 z-0 pointer-events-none opacity-90" alt="bg" />

                {/* Desktop Surface */}
                <div ref={desktopRef} onMouseDown={handleDesktopMouseDown} className="absolute inset-0 z-10 overflow-hidden outline-none" tabIndex={0}>
                    {/* Render Desktop Icons */}
                    {icons.map(icon => (
                        <DesktopIcon key={icon.id} icon={icon} isSelected={selectedIcons.has(icon.id)} onMouseDown={handleIconMouseDown} />
                    ))}

                    {/* Selection Box */}
                    {selectionBox && (
                        <div className="absolute bg-blue-500/20 border border-blue-400/50 pointer-events-none" 
                             style={{ left: selectionBox.x, top: selectionBox.y, width: selectionBox.width, height: selectionBox.height }} />
                    )}

                    {/* Render Windows */}
                    {openWindows.map(app => (
                        <Window key={app.instanceId} app={app} onClose={handleCloseWindow} onFocus={handleFocusWindow} 
                            onMinimize={id => setOpenWindows(p => p.map(w => w.instanceId === id ? { ...w, state: 'minimized' } : w))}
                            onMaximize={id => setOpenWindows(p => p.map(w => w.instanceId === id ? { ...w, state: w.state === 'maximized' ? 'open' : 'maximized' } : w))}
                            frameConstraints={desktopRef}>
                            {app.component}
                        </Window>
                    ))}
                </div>

                {/* Overlays / OS Panels */}
                <StiyaBot isOpen={() => setIsBotOpen(!isBotOpen)} isOpened={isBotOpen} />

                {/* Taskbar */}
                <div className="taskbar absolute bottom-2 left-1/2 -translate-x-1/2 h-14 bg-white/20 backdrop-blur-2xl border border-white/20 rounded-2xl shadow-2xl z-[60000] px-3 flex items-center gap-2">
                    {/* Start Button */}
                    <button onClick={() => setStartMenuOpen(!isStartMenuOpen)} className="w-10 h-10 bg-white/10 hover:bg-white/20 rounded-xl flex items-center justify-center transition-all">
                        <div className="w-4 h-4 grid grid-cols-2 gap-0.5"><div className="bg-white rounded-sm"/><div className="bg-white rounded-sm"/><div className="bg-white rounded-sm"/><div className="bg-white rounded-sm"/></div>
                    </button>
                    
                    {/* AI Search/Bot Trigger */}
                    <button onClick={() => setIsBotOpen(!isBotOpen)} className="flex items-center gap-2 bg-white/10 hover:bg-white/20 px-3 py-2 rounded-xl text-white/80 hover:text-white transition-all w-48 text-left border border-white/10">
                        <StarFourIcon size={16} /> <span className="flex-1 text-xs truncate">Ask Stiya AI...</span> <MicrophoneIcon size={14} />
                    </button>

                    <div className="w-px h-6 bg-white/20 mx-1" />

                    {/* App Icons */}
                    <div className="flex items-center gap-1">
                        {activeTaskbarApps.map(id => {
                            const app = (allApps as Record<string, AppDefinition>)[id];
                            
                            if (!app) return null;

                            const isRunning = getRunningInstances(id).length > 0;
                            const isActive = isRunning && getRunningInstances(id).some(i => i.zIndex === zIndexCounter);

                            return (
                                <button key={id} onClick={() => handleOpenApp(id)} className={`relative w-10 h-10 p-1.5 rounded-xl hover:bg-white/15 transition-all flex items-center justify-center ${isActive ? 'bg-white/20 shadow-inner border border-white/10' : ''}`}>
                                    <img src={app.icon} alt={app.name} className="w-full h-full object-contain filter drop-shadow-sm transition-transform active:scale-90" />
                                    {isRunning && <div className={`absolute bottom-0 left-1/2 -translate-x-1/2 w-3 h-1 rounded-t-full transition-colors ${isActive ? 'bg-blue-400' : 'bg-white/60'}`} />}
                                </button>
                            );
                        })}
                    </div>

                    <div className="w-px h-6 bg-white/20 mx-1" />

                    {/* System Tray */}
                    <div className="flex items-center gap-1">
                        <button className="flex items-center gap-2 px-2 py-1.5 hover:bg-white/15 rounded-xl transition-all">
                            <WifiHighIcon size={16} className="text-white" />
                            <SpeakerHighIcon size={16} className="text-white" />
                            <BatteryIcon {...batteryStatus} />
                        </button>
                        <TaskbarClock onClick={() => {}} />
                    </div>
                </div>
            </div>
        </AppManagerProvider>
    );
}