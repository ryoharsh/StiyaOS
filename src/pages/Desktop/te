// --- Types ---
export type AppInstanceRef = { id: string; instanceId: string; state?: string; zIndex?: number; icon?: any; name?: string; };
export type AppManagerAPI = { openApp: (appId: string, source?: "desktop" | "taskbar") => void; createAppInstance: (appId: string) => void; closeInstance: (instanceId: string) => void; closeAllInstancesOfApp: (appId: string) => void; getRunningInstances: (appId: string) => AppInstanceRef[]; focusInstance?: (instanceId: string) => void; };
export type BatteryStatus = { level: number; charging: boolean; };
export interface AppDefinition { id: string; name: string; defaultSize: { width: number; height: number }; icon: any; component: React.ReactNode; windowOptions?: { hideTitleBar?: boolean; customControls?: boolean; }; }
export interface AppInstance extends AppDefinition { instanceId: string; x: number; y: number; zIndex: number; state: 'opening' | 'open' | 'closing' | 'minimized' | 'maximized'; }
export interface DesktopAppInstance extends AppInstance { preview?: string; }
export type TaskbarHover = { appId: string; show: boolean; x: number; y: number; };
export type MyApp = { id: string; name: string; icon: any; x: number; y: number; };
export type SelectionBox = { x: number; y: number; width: number; height: number; };
export type WindowProps = { app: DesktopAppInstance; onClose: (id: string) => void; onFocus: (id: string) => void; onMinimize: (id: string) => void; onMaximize: (id: string) => void; frameConstraints: any; children: React.ReactNode; };

